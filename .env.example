# Copy to .env.local and fill in dev values. Never commit .env.local.
# Production values go in Vercel project settings → Environment Variables.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                # server-only, never expose to client
SUPABASE_DB_PASSWORD=                     # CLI only — used by `supabase db push` for migrations

# --- Twilio (agent SMS + STOP webhook) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                       # purchased US long-code or toll-free, E.164 format
AGENT_PHONE_NUMBER=                       # destination for new-lead alerts, E.164 format

# --- Resend (transactional email to leads) ---
RESEND_API_KEY=
FROM_EMAIL=hello@yourdomain.com

# --- Meta Conversions API ---
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=                     # used during testing only; remove from production

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
HEALTH_CHECK_SECRET=                       # gates GET /api/health; pick a random string (e.g. `openssl rand -hex 32`)
