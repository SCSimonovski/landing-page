# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (workspace-wide; matches at any depth)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (workspace-wide; matches at any depth)
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# IDE
.idea/
.vscode/

# Claude Code session-local config
.claude/

# Scratch directory for one-off files (DB backups, test data, throwaway scripts)
scratch/

# typescript
*.tsbuildinfo
next-env.d.ts
