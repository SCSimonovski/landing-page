{
  "name": "leads-generator-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter northgate-protection dev",
    "build": "pnpm --filter northgate-protection build",
    "lint": "pnpm --filter northgate-protection lint",
    "gen:types": "supabase gen types --lang=typescript --linked --schema public > packages/shared/types/database.ts",
    "verify-envs": "tsx scripts/verify-envs.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.3",
    "supabase": "^2.95.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
